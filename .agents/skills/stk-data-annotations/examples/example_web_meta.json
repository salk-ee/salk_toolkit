{
  "description": "Example WEB survey — political attitudes (7-point likert)",
  "collection_start": "2026-03-01",
  "collection_end": "2026-03-15",
  "constants": {
    "party_colors": {
      "TS-LKD": "#49a39b",
      "LSDP": "#ce2e26",
      "LVŽS": "#4aa35a",
      "Other": "lightgrey",
      "Don't know": "grey"
    },
    "md_topics": [
      "Ekonomika",
      "Sveikata",
      "Gynyba",
      "Švietimas"
    ],
    "md_sets": [
      [[1, 2, 3], [1, 3, 4], [2, 3, 4]],
      [[1, 2, 4], [2, 3, 4], [1, 3, 4]]
    ]
  },
  "files": [{ "file": "example_web_data.csv", "code": "W" }],
  "structure": [
    {
      "name": "main",
      "columns": [
        ["gender", "D1", {
          "categories": ["Female", "Male"],
          "translate": { "Moteris": "Female", "Vyras": "Male" },
          "label": "Gender"
        }],
        ["age", "D2", { "continuous": true, "label": "Age" }],
        ["age_group", "D2", {
          "categories": "infer",
          "transform": "stk.cut_nice(s, [18, 30, 45, 60, 75])",
          "ordered": true,
          "label": "Age group"
        }],
        ["education", "D3", {
          "categories": ["Primary", "Secondary", "Higher"],
          "translate": {
            "Žemas": "Primary",
            "Vidutinis": "Secondary",
            "Aukštas": "Higher"
          },
          "ordered": true,
          "num_values": [1, 2, 3],
          "label": "Highest education level"
        }],
        ["method", "D1", {
          "categories": ["web", "cati"],
          "transform": "pd.Series('web', index=s.index)"
        }],
        ["party_preference", "Q1", {
          "categories": "infer",
          "translate": {
            "Tėvynės sąjunga": "TS-LKD",
            "Socialdemokratai": "LSDP",
            "Valstiečiai": "LVŽS",
            "Kita partija": "Other",
            "Nežinau": "Don't know"
          },
          "label": "Which party would you vote for?",
          "colors": "party_colors"
        }]
      ]
    },
    {
      "name": "attitudes",
      "scale": {
        "col_prefix": "attitude_",
        "categories": ["-3", "-2", "-1", "0", "1", "2", "3"],
        "translate": {
          "1 - visiškai nesutinku": 1, "1": 1,
          "2": 2, "3": 3,
          "4 - neutraliai": 4, "4": 4,
          "5": 5, "6": 6,
          "7 - visiškai sutinku": 7, "7": 7
        },
        "transform": "(s.astype('int')-4).astype('str')",
        "ordered": true,
        "likert": true
      },
      "columns": [
        ["pol_interest", "Q2r1", {
          "label": "I follow politics closely — I rarely follow politics"
        }],
        ["future", "Q2r2", {
          "label": "Optimistic about the future — Pessimistic about the future"
        }]
      ]
    },
    {
      "name": "thermometer",
      "comment": "Demonstrates `scale.question_colors` — coloring each column (party) with its brand color when the block is unpivoted in plots. The likert `colors` gradient for the scale values is derived automatically; `question_colors` handles the orthogonal dimension (which party). Thermometer column names must match keys in `party_colors`. Marked `generated: true` so no raw data is required in this example.",
      "generated": true,
      "scale": {
        "categories": ["Strongly dislike", "Dislike", "Like", "Strongly like"],
        "ordered": true,
        "likert": true,
        "num_values": [-2, -1, 1, 2],
        "question_colors": "party_colors"
      },
      "columns": [["TS-LKD"], ["LSDP"], ["LVŽS"]]
    },
    {
      "name": "attitudes_p",
      "generated": true,
      "scale": {
        "col_prefix": "attitude_",
        "categories": ["-2", "-1", "0", "1", "2"],
        "translate": {
          "1 - visiškai nesutinku": 1, "1": 1,
          "2": 2,
          "3 - neutraliai": 3, "3": 3,
          "4": 4,
          "5 - visiškai sutinku": 5, "5": 5
        },
        "transform": "(s.astype('int')-3).astype('str')",
        "ordered": true,
        "likert": true
      },
      "columns": [["pol_interest_p"], ["future_p"]]
    },
    {
      "name": "issue_importance",
      "type": "topk",
      "from_columns": "Q3r(\\d+)",
      "res_columns": "Q3_R\\1",
      "agg_index": 1,
      "na_vals": [
        "NO TO: Ekonomika",
        "NO TO: Sveikata",
        "NO TO: Gynyba",
        "NO TO: Švietimas"
      ],
      "scale": {
        "categories": "infer",
        "translate_after": {
          "1": "Economy",
          "2": "Healthcare",
          "3": "Defence",
          "4": "Education"
        }
      },
      "columns": []
    },
    {
      "name": "maxdiff",
      "type": "maxdiff",
      "columns": [],
      "best_columns": "Q4_(\\d+?)best",
      "worst_columns": "Q4_(\\d+?)worst",
      "set_columns": "Q4_\\1set",
      "setindex_column": ["Q4_Version", { "continuous": true }],
      "input_format": "choice_sets",
      "choice_sets": [
        [[1, 2, 3], [1, 3, 4], [2, 3, 4]],
        [[1, 2, 4], [2, 3, 4], [1, 3, 4]]
      ],
      "scale": {
        "categories": "infer",
        "translate": {
          "1": "Economy",
          "2": "Healthcare",
          "3": "Defence",
          "4": "Education"
        }
      }
    }
  ]
}
